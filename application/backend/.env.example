# Backend environment configuration
# Copy to .env and fill in values

PORT=3001
LOG_LEVEL=info

# Fabric network
CHANNEL_NAME=goplatformchannel
CHAINCODE_NAME=golifecycle

# Peer endpoints
ISSUER_PEER_ENDPOINT=localhost:7051
PRODUCER_PEER_ENDPOINT=localhost:9051
CONSUMER_PEER_ENDPOINT=localhost:11051

# TLS certificates (absolute paths)
ISSUER_TLS_CERT=../network/organizations/peerOrganizations/issuer1.go-platform.com/peers/peer0.issuer1.go-platform.com/tls/ca.crt
PRODUCER_TLS_CERT=../network/organizations/peerOrganizations/producer1.go-platform.com/peers/peer0.producer1.go-platform.com/tls/ca.crt
CONSUMER_TLS_CERT=../network/organizations/peerOrganizations/consumer1.go-platform.com/peers/peer0.consumer1.go-platform.com/tls/ca.crt

# Crypto material base path
CRYPTO_PATH=../network/organizations

# JWT secret (change in production!)
JWT_SECRET=go-platform-dev-secret
